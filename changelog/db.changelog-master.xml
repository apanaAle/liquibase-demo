<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="1" author="intern">
        <sqlFile path="changelog/scripts/v1__create_users.sql"
                 relativeToChangelogFile="false"/>
        <rollback>DROP TABLE users;</rollback>
    </changeSet>

    <changeSet id="2" author="intern">
        <sqlFile path="changelog/scripts/v2__add_email_column.sql"
                 relativeToChangelogFile="false"/>
        <rollback>ALTER TABLE users DROP COLUMN email;</rollback>
    </changeSet>

    <changeSet id="3" author="intern">
        <sqlFile path="changelog/scripts/v3__insert_data.sql"
                 relativeToChangelogFile="false"/>
        <rollback>DELETE FROM users;</rollback>
    </changeSet>

</databaseChangeLog>
